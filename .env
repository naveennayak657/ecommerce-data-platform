# Project: E-Commerce Real-Time Data Platform
#
# Environment variables for local development
# NEVER commit this file to GitHub with real credentials
# ──────────────────────────────────────────────────

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=ecommerce-events
KAFKA_RETRIES=3
KAFKA_ACKS=all

# Producer
PRODUCER_SLEEP_INTERVAL=1
PRODUCER_FLUSH_INTERVAL=10

# Delta Lake paths
BRONZE_PATH=./delta_lake/bronze
SILVER_PATH=./delta_lake/silver
GOLD_PATH=./delta_lake/gold
CHECKPOINT_PATH=./delta_lake/checkpoints