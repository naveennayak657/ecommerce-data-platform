# environment variables — contains sensitive credentials
.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Delta Lake data files
delta_lake/data/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Airflow
airflow/logs/

# Mac system files
.DS_Store

# VS Code
.vscode/

# Jupyter
.ipynb_checkpoints/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
